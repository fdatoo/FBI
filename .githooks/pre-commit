#!/usr/bin/env bash
set -euo pipefail

ROOT="$(git rev-parse --show-toplevel)"
fail=0

# Gleam format check — runs only when .gleam files are staged
if git diff --cached --name-only | grep -qE '\.gleam$'; then
  if command -v gleam >/dev/null 2>&1; then
    echo "→ gleam format --check"
    if ! (cd "$ROOT/src/server" && gleam format --check 2>&1); then
      echo "  Fix: cd src/server && gleam format"
      fail=1
    fi
  fi
fi

# Rust format check — runs only when .rs or Cargo files are staged
if git diff --cached --name-only | grep -qE '\.rs$|Cargo\.(toml|lock)$'; then
  if command -v cargo >/dev/null 2>&1; then
    echo "→ cargo fmt --check"
    if ! (cd "$ROOT" && cargo fmt --check 2>&1); then
      echo "  Fix: cargo fmt"
      fail=1
    fi
  fi
fi

exit $fail
